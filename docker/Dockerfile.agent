# =============================================================================
# MnM Agent Pod — Docker Image
# =============================================================================
# Per-user persistent container for running agents with Claude CLI.
# Pre-installs: Node.js, git, Claude Code, common build tools.
#
# Build:
#   docker build -f docker/Dockerfile.agent -t mnm-agent:latest .
# =============================================================================

FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates python3 build-essential openssh-client jq \
    && npm install -g @anthropic-ai/claude-code@latest \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash agent

# Create workspace directory
RUN mkdir -p /workspace && chown agent:agent /workspace

USER agent
WORKDIR /home/agent

ENV HOME=/home/agent
ENV PATH="/home/agent/.local/bin:$PATH"

# Keep container alive (used as persistent pod)
CMD ["sleep", "infinity"]
